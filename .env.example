# Shopify Storefront API Configuration
# Required for blog functionality

# Your Shopify store domain (e.g., your-store.myshopify.com)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront Private Token (Headless channel)
# This is the ONLY header that works with Headless channel private tokens
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=your_storefront_private_token_here
